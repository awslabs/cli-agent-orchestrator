#!/usr/bin/env bash
# caoctl — run CAO control commands against one fleet node over your private network.
#   caoctl <node> <cao args...>   e.g. caoctl node-b session list
#   caoctl --show <node>          print the resolved API base URL
#   caoctl --list                 list node names + hosts
#
# The node registry is read from $CAO_FLEET_CONFIG, defaulting to fleet.json next
# to this example (copy fleet.example.json -> fleet.json first). A node's "host"
# may be any address the coordinator can reach it at: a Tailscale/WireGuard IP, a
# LAN IP, or a DNS name.
set -euo pipefail
HERE="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
FLEET="${CAO_FLEET_CONFIG:-$HERE/../fleet.json}"

if [ ! -f "$FLEET" ]; then
  echo "caoctl: no fleet registry at '$FLEET'" >&2
  echo "        copy fleet.example.json -> fleet.json and edit it, or set CAO_FLEET_CONFIG." >&2
  exit 2
fi

_resolve() { # node -> "<host> <port>"; exit 1 if unknown
  python3 - "$FLEET" "$1" <<'PY'
import json, sys
cfg = json.load(open(sys.argv[1]))
port = cfg.get("port", 9889)
nodes = {x["name"]: x for x in cfg["machines"]}
name = sys.argv[2]
if name not in nodes:
    sys.stderr.write(f"caoctl: unknown node '{name}'\n"); sys.exit(1)
print(nodes[name]["host"], nodes[name].get("port", port))
PY
}

usage() { echo "usage: caoctl <node> <cao args...> | caoctl --show <node> | caoctl --list" >&2; }

[ $# -lt 1 ] && { usage; exit 2; }

case "$1" in
  --list)
    python3 -c "import json;[print(x['name'], x['host']) for x in json.load(open('$FLEET'))['machines']]"
    exit 0 ;;
  --show)
    [ $# -lt 2 ] && { usage; exit 2; }
    read -r host port < <(_resolve "$2") || exit 1
    echo "http://$host:$port"; exit 0 ;;
  -h|--help) usage; exit 0 ;;
esac

node="$1"; shift
read -r host port < <(_resolve "$node") || exit 1
exec env CAO_API_HOST="$host" CAO_API_PORT="$port" cao "$@"
