{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "sqs-monitor",
  "description": "Poll an SQS queue until all messages are consumed",
  "type": "object",
  "properties": {
    "profile": {
      "type": "string",
      "description": "AWS CLI profile name"
    },
    "region": {
      "type": "string",
      "description": "AWS region",
      "pattern": "^[a-z]{2}-[a-z]+-[0-9]+$"
    },
    "queue_url": {
      "type": "string",
      "description": "Full SQS queue URL",
      "pattern": "^https://sqs\\..+\\.amazonaws\\.com/.+"
    },
    "poll_interval_seconds": {
      "type": "integer",
      "description": "Seconds between polls",
      "minimum": 1,
      "default": 10
    },
    "timeout_seconds": {
      "type": "integer",
      "description": "Max wait time in seconds",
      "minimum": 10,
      "default": 300
    }
  },
  "required": ["profile", "region", "queue_url"],
  "additionalProperties": false
}
